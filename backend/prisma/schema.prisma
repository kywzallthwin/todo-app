generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  todos    Todo[]
}

model Todo {
  id     Int     @id @default(autoincrement())
  text   String
  done   Boolean @default(false)
  userId Int
  user   User    @relation(fields: [userId], references: [id])
}